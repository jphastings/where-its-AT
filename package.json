{
  "name": "where-its-at",
  "version": "0.4.0",
  "description": "Browser extension that highlights atproto references on the current page.",
  "private": true,
  "type": "module",
  "scripts": {
    "icons": "tsx scripts/generate-icons.ts",
    "prebuild": "pnpm icons",
    "prebuild:chrome": "pnpm icons",
    "prebuild:firefox": "pnpm icons",
    "predev": "pnpm icons",
    "predev:firefox": "pnpm icons",
    "build": "pnpm build:chrome && pnpm build:firefox",
    "build:chrome": "vite build --mode chrome",
    "build:firefox": "vite build --mode firefox",
    "dev": "vite",
    "dev:firefox": "vite --mode firefox",
    "zip": "pnpm build && node scripts/zip.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^22.10.0",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-web-extension": "^4.4.3"
  },
  "packageManager": "pnpm@11.1.0"
}
